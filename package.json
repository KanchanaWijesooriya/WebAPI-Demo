{
  "name": "ntc-bus-tracking-api",
  "version": "1.0.0",
  "description": "Real-Time Bus Tracking System API for Sri Lanka National Transport Commission",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest --silent",
    "test:routes": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest routes.test.js --silent",
    "test:basic-auth": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest basic-auth.test.js --silent",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest --coverage --silent",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "seed": "node scripts/seed.js seed",
    "seed:quick": "node scripts/seed.js quick",
    "seed:clear": "node scripts/seed.js clear"
  },
  "keywords": [
    "bus-tracking",
    "rest-api",
    "real-time",
    "gps",
    "sri-lanka",
    "transport"
  ],
  "author": "cobsccomp24.1p-020",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.3",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.2"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.2.1",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
